# Copy to .env for local development. All variables are prefixed WALKER_.

# SQLAlchemy database URL. POC default: embedded SQLite on a local file.
# Switch to an external DBMS later, e.g.:
#   postgresql+psycopg://user:pass@host:5432/walker
#   mssql+pyodbc://user:pass@host/walker?driver=ODBC+Driver+18+for+SQL+Server
WALKER_DATABASE_URL=sqlite:///./walker.db

# The implicit single user for the POC (see ADR-0007).
WALKER_DEFAULT_USER=me
