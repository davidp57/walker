# Copy to .env for local development. All variables are prefixed WALKER_.

# SQLAlchemy database URL. POC default: embedded SQLite on a local file.
# Switch to an external DBMS later, e.g.:
#   postgresql+psycopg://user:pass@host:5432/walker
#   mssql+pyodbc://user:pass@host/walker?driver=ODBC+Driver+18+for+SQL+Server
WALKER_DATABASE_URL=sqlite:///./walker.db

# The implicit single user for the POC (see ADR-0007).
WALKER_DEFAULT_USER=me

# Deployment-mode switch (see ADR-0010). "none" (default) is the standalone Docker/.exe
# behavior: no login, implicit default user above. "sso" is the hosted deployment: OAuth2/OIDC
# login against Google, Apple, or Microsoft is required on every request.
WALKER_AUTH_MODE=none

# Required when WALKER_AUTH_MODE=sso: signs the session cookie. Generate a real secret per
# hosted deployment, e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
WALKER_SESSION_SECRET=dev-insecure-secret-change-me

# OAuth client credentials, one pair per provider, only needed when WALKER_AUTH_MODE=sso.
# Register an app with each provider to obtain these (see BIZ-029) — a human, one-time,
# per-deployment prerequisite; never required for the standalone Docker/.exe targets.
WALKER_GOOGLE_CLIENT_ID=
WALKER_GOOGLE_CLIENT_SECRET=
WALKER_APPLE_CLIENT_ID=
WALKER_APPLE_CLIENT_SECRET=
WALKER_MICROSOFT_CLIENT_ID=
WALKER_MICROSOFT_CLIENT_SECRET=
