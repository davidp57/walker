{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "walker-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev", "--", "--port", "5173", "--strictPort"],
      "port": 5173
    },
    {
      "name": "walker-backend",
      "runtimeExecutable": ".venv/Scripts/uvicorn.exe",
      "runtimeArgs": ["walker.api.app:app", "--port", "8000"],
      "port": 8000
    }
  ]
}
