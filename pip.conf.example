# Copy this file to pip.conf and fill in your Artifactory credentials.
# pip.conf is git-ignored — never commit real credentials.
#
# How to get your API key:
#   1. Log in to https://artifacts-central.pwc.com
#   2. Click your username (top-right) → Edit Profile → Authentication Settings → Generate API Key
#
# Then install with: pip install --config-settings ... or set PIP_CONFIG_FILE=./pip.conf
#
[global]
index-url = https://YOUR_USERNAME:YOUR_API_KEY@artifacts-central.pwc.com/artifactory/api/pypi/c00060-pwc-lu-ifs-pypi/simple
trusted-host = artifacts-central.pwc.com
